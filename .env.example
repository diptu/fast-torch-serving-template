# Copy to .env and adjust as needed. Only secrets and machine-/infra-
# specific settings live here — static defaults (deployment environment,
# log level, ML hyperparameters, paths, MLflow/OTel identifiers) live in
# configs/default.yaml instead, since they're safe to commit and rarely
# need a per-machine override. Precedence, highest first:
# environment variables (below) > .env file > configs/default.yaml > the
# defaults in Settings.

# --- Admin API ---
# Enables POST /admin/reload-model, guarded by this shared secret sent as
# the X-Admin-Token header. Leave unset to keep the endpoint disabled.
APP_ADMIN_TOKEN=

# Optional: require this value as the X-API-Key header on /v1/predict.
# Leave unset to keep it open (the default, unchanged behavior).
APP_PREDICT_API_KEY=

# Optional: require this value as the X-Metrics-Token header on GET
# /metrics. Leave unset to keep it open (the default, unchanged behavior)
# — fine behind a private network, but set this (or put the endpoint behind
# an upstream gateway) before exposing the API publicly.
APP_METRICS_TOKEN=

# --- CORS ---
# No origins allowed by default — this is an API template with no known
# frontend, so "locked down until configured" is the safe default, and
# there's no one sensible default across deployments to put in
# configs/default.yaml. This is a JSON list, not comma-separated — quote it
# as shown if you set it.
# APP_CORS_ALLOW_ORIGINS=["https://your-frontend.example.com"]

# --- Serving / concurrency ---
# Caps concurrent /v1/predict inferences per worker process. Defaults to
# this machine's CPU core count (inference is CPU-bound) if left unset —
# deliberately not a static default in configs/default.yaml, since the
# right value depends on the machine/container it runs on, not on the
# deployment. Uncomment to override. A request that can't get a slot within
# APP_PREDICTION_QUEUE_TIMEOUT_SECONDS (see configs/default.yaml) gets a
# 503 with Retry-After instead of queueing indefinitely.
# APP_MAX_CONCURRENT_PREDICTIONS=8

# --- Observability ---
# Distributed tracing (OpenTelemetry) is off unless you set an OTLP
# endpoint — there's no bundled collector (Jaeger/Tempo/etc), and the right
# endpoint is infra-specific, so it's not a static default. Uncomment to
# enable:
# APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Git commit this image was built from, surfaced via GET /version. Normally
# set by the Dockerfile's GIT_SHA build arg (see the CD workflow), not by
# hand — "unknown" if left unset, e.g. running outside Docker.
# APP_GIT_SHA=
